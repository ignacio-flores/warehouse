  url = {https://doi.org/10.1007/s10888-022-09536-8},
  abstract = {This article first describes the main developments in measuring the upper tail of the income and wealth distributions over the last twenty years. Second, it points out some of the key methodological challenges and how better data could address them. Third, it discusses the academic and policy impacts of upper tail measurement.},
